  {%- assign stashbox_related_links = stashbox_related_collections | strip | split: '|' -%}
  {%- assign stashbox_rendered_handles = '|' -%}

  {%- style -%}
    .stashbox-related-collections {
      margin-top: 2rem;
      padding: 1.5rem;
      border: 0.1rem solid rgba(var(--color-foreground), 0.12);
      border-radius: 1.2rem;
      background: rgba(var(--color-foreground), 0.03);
    }

    .stashbox-related-collections__heading {
      margin: 0 0 0.6rem;
      font-size: clamp(1.8rem, 2vw, 2.4rem);
      line-height: 1.25;
    }

    .stashbox-related-collections__copy {
      max-width: 72rem;
      margin: 0 0 1.4rem;
      color: rgba(var(--color-foreground), 0.75);
      font-size: 1.4rem;
      line-height: 1.5;
    }

    .stashbox-related-collections__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
      gap: 1rem;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .stashbox-related-collections__card {
      display: flex;
      height: 100%;
      flex-direction: column;
      overflow: hidden;
      border: 0.1rem solid rgba(var(--color-foreground), 0.14);
      border-radius: 1rem;
      color: rgb(var(--color-foreground));
      background: rgb(var(--color-background));
      text-decoration: none;
      transition: border-color var(--duration-short) ease, box-shadow var(--duration-short) ease, transform var(--duration-short) ease;
    }

    .stashbox-related-collections__card:hover,
    .stashbox-related-collections__card:focus-visible {
      border-color: rgba(var(--color-foreground), 0.45);
      box-shadow: 0 0.6rem 1.8rem rgba(var(--color-foreground), 0.12);
      transform: translateY(-0.1rem);
    }

    .stashbox-related-collections__card:focus-visible {
      outline: 0.2rem solid rgba(var(--color-foreground), 0.85);
      outline-offset: 0.3rem;
    }

    .stashbox-related-collections__media {
      display: flex;
      width: 100%;
      aspect-ratio: 11 / 8;
      align-items: center;
      justify-content: center;
      background: #f7f7f7;
    }

    .stashbox-related-collections__image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: contain;
      background: #f7f7f7;
    }

    .stashbox-related-collections__placeholder {
      padding: 1rem;
      color: rgba(var(--color-foreground), 0.62);
      font-size: 1.2rem;
      line-height: 1.35;
      text-align: center;
    }

    .stashbox-related-collections__content {
      display: flex;
      flex: 1;
      flex-direction: column;
      gap: 0.35rem;
      padding: 1rem;
    }

    .stashbox-related-collections__title {
      font-weight: 700;
      line-height: 1.25;
    }

    .stashbox-related-collections__label {
      color: rgba(var(--color-foreground), 0.72);
      font-size: 1.2rem;
      line-height: 1.35;
    }

    @media screen and (min-width: 990px) {
      .stashbox-related-collections__grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }
    }

    @media screen and (max-width: 749px) {
      .stashbox-related-collections {
        margin-top: 1.5rem;
        padding: 1.2rem;
      }

      .stashbox-related-collections__grid {
        grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
      }
    }
  {%- endstyle -%}

  <nav class="stashbox-related-collections" aria-labelledby="stashbox-related-collections-heading">
    <h2 class="stashbox-related-collections__heading" id="stashbox-related-collections-heading">
      Explore Related STASHBOX.AI Collections
    </h2>
    <p class="stashbox-related-collections__copy">
      Discover more STASHBOX.AI merch collections connected by music, artwork, style, and original visual culture.
    </p>
    <ul class="stashbox-related-collections__grid">
      {%- for stashbox_related_link in stashbox_related_links -%}
        {%- assign stashbox_related_parts = stashbox_related_link | strip | split: '::' -%}
        {%- assign stashbox_related_handle = stashbox_related_parts[0] | strip -%}
        {%- assign stashbox_related_title = stashbox_related_parts[1] | strip -%}
        {%- assign stashbox_related_label = stashbox_related_parts[2] | strip -%}
        {%- assign stashbox_related_collection = collections[stashbox_related_handle] -%}
        {%- assign stashbox_handle_token = '|' | append: stashbox_related_handle | append: '|' -%}

        {%- assign stashbox_is_duplicate = false -%}
        {%- if stashbox_rendered_handles contains stashbox_handle_token -%}
          {%- assign stashbox_is_duplicate = true -%}
        {%- endif -%}

        {%- if stashbox_related_collection != blank
          and stashbox_related_collection.url != blank
          and stashbox_related_handle != collection.handle
          and stashbox_is_duplicate == false
        -%}
          {%- assign stashbox_rendered_handles = stashbox_rendered_handles | append: stashbox_related_handle | append: '|' -%}
          {%- assign stashbox_related_image = stashbox_related_collection.image | default: stashbox_related_collection.featured_image -%}

          <li class="stashbox-related-collections__item">
            <a class="stashbox-related-collections__card" href="{{ stashbox_related_collection.url }}">
              <span class="stashbox-related-collections__media">
                {%- if stashbox_related_image != blank -%}
                  <img
                    class="stashbox-related-collections__image"
                    src="{{ stashbox_related_image | image_url: width: 440 }}"
                    alt="{{ stashbox_related_collection.title | append: ' collection at STASHBOX.AI' | escape }}"
                    width="440"
                    height="320"
                    loading="lazy"
                  >
                {%- else -%}
                  <span class="stashbox-related-collections__placeholder" aria-hidden="true">
                    Collection image coming soon
                  </span>
                {%- endif -%}
              </span>
              <span class="stashbox-related-collections__content">
                <span class="stashbox-related-collections__title">{{ stashbox_related_title | escape }}</span>
                {%- if stashbox_related_label != blank -%}
                  <span class="stashbox-related-collections__label">{{ stashbox_related_label | escape }}</span>
                {%- endif -%}
              </span>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </nav>
{%- endif -%}
