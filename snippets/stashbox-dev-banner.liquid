{% comment %}
  DEV ONLY TEST BANNER - REMOVE BEFORE PRODUCTION LAUNCH
{% endcomment %}

<style>
  #stashbox-dev-banner {
    align-items: center;
    background: #111827;
    color: #ffffff;
    display: flex;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 13px;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.08em;
    line-height: 1.4;
    min-height: 36px;
    padding: 8px 44px;
    position: relative;
    text-align: center;
    text-transform: uppercase;
    width: 100%;
    z-index: 1000;
  }

  .stashbox-dev-banner__close {
    align-items: center;
    appearance: none;
    background: transparent;
    border: 0;
    color: #ffffff;
    cursor: pointer;
    display: flex;
    font: inherit;
    height: 100%;
    justify-content: center;
    padding: 0 16px;
    position: absolute;
    right: 0;
    top: 0;
  }

  .stashbox-dev-banner__close:hover,
  .stashbox-dev-banner__close:focus-visible {
    background: rgba(255, 255, 255, 0.16);
  }
</style>

<div id="stashbox-dev-banner" class="stashbox-dev-banner" role="status">
  <span class="stashbox-dev-banner__message">STASHBOX.AI DEV TEMPLATE ONLY - NOT LIVE</span>
  <button class="stashbox-dev-banner__close" type="button" aria-label="Close dev notice">&times;</button>
</div>

<script>
  (function () {
    var storageKey = 'stashbox-dev-banner-dismissed';
    var banner = document.getElementById('stashbox-dev-banner');

    if (!banner) {
      return;
    }

    try {
      if (window.localStorage.getItem(storageKey) === 'true') {
        banner.style.display = 'none';
        return;
      }
    } catch (error) {
      // Keep banner visible if localStorage is unavailable.
    }

    var closeButton = banner.querySelector('.stashbox-dev-banner__close');
    if (!closeButton) {
      return;
    }

    closeButton.addEventListener('click', function () {
      banner.style.display = 'none';

      try {
        window.localStorage.setItem(storageKey, 'true');
      } catch (error) {
        // Dismiss for this page view even if localStorage is unavailable.
      }
    });
  })();
</script>
