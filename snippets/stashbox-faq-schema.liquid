{% comment %}
  STASHBOX SEO/AIO SCHEMA PHASE 1

  FAQPage JSON-LD support is intentionally gated to pages that render the
  visible FAQ block from the same custom.faq_#_question/custom.faq_#_answer
  metafields. The supported metafield keys are custom.faq_1_question through
  custom.faq_5_answer.
{% endcomment %}
{%- liquid
  assign stashbox_faq_source = blank
  assign stashbox_has_faq = false

  if request.page_type == 'product' and product
    assign stashbox_faq_source = product
  elsif request.page_type == 'collection' and collection
    assign stashbox_faq_source = collection
  endif
-%}

{%- if stashbox_faq_source != blank -%}
  {%- capture stashbox_faq_entities -%}
    {%- for stashbox_index in (1..5) -%}
      {%- assign stashbox_question_key = 'faq_' | append: stashbox_index | append: '_question' -%}
      {%- assign stashbox_answer_key = 'faq_' | append: stashbox_index | append: '_answer' -%}
      {%- assign stashbox_question = stashbox_faq_source.metafields.custom[stashbox_question_key] -%}
      {%- assign stashbox_answer = stashbox_faq_source.metafields.custom[stashbox_answer_key] -%}
      {%- if stashbox_question != blank and stashbox_answer != blank -%}
        {%- if stashbox_has_faq -%},{%- endif -%}
        {
          "@type": "Question",
          "name": {{ stashbox_question | metafield_text | strip_html | strip | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ stashbox_answer | metafield_text | strip_html | strip | json }}
          }
        }
        {%- assign stashbox_has_faq = true -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}

  {%- if stashbox_has_faq -%}
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
{{ stashbox_faq_entities }}
  ]
}
    </script>
  {%- endif -%}
{%- endif -%}
