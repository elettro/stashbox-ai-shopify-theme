{% comment %}
  STASHBOX SEO/AIO SCHEMA PHASE 1

  FAQPage JSON-LD support is intentionally gated to pages that render the
  visible FAQ block from the same custom.faq_#_question/custom.faq_#_answer
  metafields. The supported metafield keys are custom.faq_1_question through
  custom.faq_5_answer.
{% endcomment %}
{%- liquid
  assign stashbox_faq_source = blank
  assign stashbox_has_faq = false

  if request.page_type == 'product' and product
    assign stashbox_faq_source = product
  elsif request.page_type == 'collection' and collection
    assign stashbox_faq_source = collection
  endif
-%}

{%- if stashbox_faq_source != blank -%}
  {%- capture stashbox_faq_entities -%}
    {%- liquid
      assign stashbox_question = stashbox_faq_source.metafields.custom.faq_1_question
      assign stashbox_answer = stashbox_faq_source.metafields.custom.faq_1_answer
      assign stashbox_question_text = stashbox_question | metafield_text | strip_html | strip
      assign stashbox_answer_text = stashbox_answer | metafield_text | strip_html | strip
    -%}
    {%- if stashbox_question_text != blank and stashbox_answer_text != blank -%}
      {%- if stashbox_has_faq -%},{%- endif -%}
      {
        "@type": "Question",
        "name": {{ stashbox_question_text | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ stashbox_answer_text | json }}
        }
      }
      {%- assign stashbox_has_faq = true -%}
    {%- endif -%}

    {%- liquid
      assign stashbox_question = stashbox_faq_source.metafields.custom.faq_2_question
      assign stashbox_answer = stashbox_faq_source.metafields.custom.faq_2_answer
      assign stashbox_question_text = stashbox_question | metafield_text | strip_html | strip
      assign stashbox_answer_text = stashbox_answer | metafield_text | strip_html | strip
    -%}
    {%- if stashbox_question_text != blank and stashbox_answer_text != blank -%}
      {%- if stashbox_has_faq -%},{%- endif -%}
      {
        "@type": "Question",
        "name": {{ stashbox_question_text | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ stashbox_answer_text | json }}
        }
      }
      {%- assign stashbox_has_faq = true -%}
    {%- endif -%}

    {%- liquid
      assign stashbox_question = stashbox_faq_source.metafields.custom.faq_3_question
      assign stashbox_answer = stashbox_faq_source.metafields.custom.faq_3_answer
      assign stashbox_question_text = stashbox_question | metafield_text | strip_html | strip
      assign stashbox_answer_text = stashbox_answer | metafield_text | strip_html | strip
    -%}
    {%- if stashbox_question_text != blank and stashbox_answer_text != blank -%}
      {%- if stashbox_has_faq -%},{%- endif -%}
      {
        "@type": "Question",
        "name": {{ stashbox_question_text | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ stashbox_answer_text | json }}
        }
      }
      {%- assign stashbox_has_faq = true -%}
    {%- endif -%}

    {%- liquid
      assign stashbox_question = stashbox_faq_source.metafields.custom.faq_4_question
      assign stashbox_answer = stashbox_faq_source.metafields.custom.faq_4_answer
      assign stashbox_question_text = stashbox_question | metafield_text | strip_html | strip
      assign stashbox_answer_text = stashbox_answer | metafield_text | strip_html | strip
    -%}
    {%- if stashbox_question_text != blank and stashbox_answer_text != blank -%}
      {%- if stashbox_has_faq -%},{%- endif -%}
      {
        "@type": "Question",
        "name": {{ stashbox_question_text | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ stashbox_answer_text | json }}
        }
      }
      {%- assign stashbox_has_faq = true -%}
    {%- endif -%}

    {%- liquid
      assign stashbox_question = stashbox_faq_source.metafields.custom.faq_5_question
      assign stashbox_answer = stashbox_faq_source.metafields.custom.faq_5_answer
      assign stashbox_question_text = stashbox_question | metafield_text | strip_html | strip
      assign stashbox_answer_text = stashbox_answer | metafield_text | strip_html | strip
    -%}
    {%- if stashbox_question_text != blank and stashbox_answer_text != blank -%}
      {%- if stashbox_has_faq -%},{%- endif -%}
      {
        "@type": "Question",
        "name": {{ stashbox_question_text | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ stashbox_answer_text | json }}
        }
      }
      {%- assign stashbox_has_faq = true -%}
    {%- endif -%}
  {%- endcapture -%}

  {%- if stashbox_has_faq -%}
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
{{ stashbox_faq_entities }}
  ]
}
    </script>
  {%- endif -%}
{%- endif -%}
